{
  "_comment": "Attach this policy to your Lambda execution role in IAM.",
  "_setup": "IAM > Roles > [your Lambda role] > Add permissions > Create inline policy > paste this JSON.",

  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3RemediationPermissions",
      "Effect": "Allow",
      "Action": [
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutBucketVersioning",
        "s3:GetBucketVersioning",
        "s3:PutBucketPolicy",
        "s3:DeleteBucketPolicy",
        "s3:GetBucketPolicy",
        "s3:GetBucketPolicyStatus",
        "s3:PutBucketAcl",
        "s3:GetBucketAcl"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsPermissions",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
